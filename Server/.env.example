# ─── LOCAL DEVELOPMENT ─────────────────────────────────────────────

# Database (local PostgreSQL)
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name

# Server
PORT=5000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=your_jwt_secret

# LLM Chat (Groq — free, 30 req/min)
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_key

# Embeddings (Voyage AI — free 200M tokens)
# Get key: https://dashboard.voyageai.com
VOYAGE_API_KEY=pa-your_voyage_key

# Embeddings local fallback (Ollama — used when VOYAGE_API_KEY not set)
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Web search (Tavily — free 1000 req/month)
TAVILY_API_KEY=tvly-your_tavily_key

# File storage (Cloudinary — free 25GB)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
