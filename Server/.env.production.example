# ─── PRODUCTION (Render) ───────────────────────────────────────────
NODE_ENV=production

# Database (Neon — free PostgreSQL with pgvector)
DATABASE_URL=postgresql://user:pass@ep-xyz.region.aws.neon.tech/dbname?sslmode=require

# Server
PORT=5000
CORS_ORIGIN=https://your-app.vercel.app
JWT_SECRET=generate-with-openssl-rand-hex-32

# LLM Chat (Groq — free, 30 req/min)
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_key

# Embeddings (Voyage AI — free 200M tokens)
VOYAGE_API_KEY=pa-your_voyage_key

# Web search (Tavily — free 1000 req/month)
TAVILY_API_KEY=tvly-your_tavily_key

# File storage (Cloudinary — free 25GB)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
